# USDCx Automation Keeper Bot Configuration
# ===========================================

# Required: Your Aleo private key
PRIVATE_KEY=APrivateKey1zkp...

# Optional: Program ID (default: usdcx_automation_hub.aleo)
PROGRAM_ID=usdcx_automation_hub.aleo

# Optional: Network (default: testnet)
NETWORK=testnet

# Optional: Network ID (default: 1)
NETWORK_ID=1

# Optional: API endpoint (default: https://api.explorer.provable.com/v1/testnet)
API_ENDPOINT=https://api.explorer.provable.com/v1/testnet

# Optional: Query endpoint (default: https://api.explorer.provable.com/v1)
QUERY_ENDPOINT=https://api.explorer.provable.com/v1

# Optional: Broadcast endpoint (default: https://api.explorer.provable.com/v1/testnet/transaction/broadcast)
BROADCAST_ENDPOINT=https://api.explorer.provable.com/v1/testnet/transaction/broadcast

# Optional: Block polling interval in milliseconds (default: 15000)
BLOCK_INTERVAL=15000

# Optional: API port (default: 3002)
API_PORT=3002

# Optional: Frontend origin for CORS (default: *)
FRONTEND_ORIGIN=*

# Optional: Price oracle URL for conditional transfers
PRICE_ORACLE_URL=
