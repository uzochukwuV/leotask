# ================================================================
# Leotask Keeper Bot - Environment Variables
# ================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Keeper wallet (the address that receives ScheduledTransfer records) ──
PRIVATE_KEY=APrivateKey1...
VIEW_KEY=AViewKey1...

# ── Provable API (for scanning records owned by the keeper) ──
# Get credentials at: https://provable.com
PROVABLE_CONSUMER_ID=your-consumer-id
PROVABLE_API_KEY=your-api-key

# ── Block to start scanning from (set to current testnet block on first run) ──
# Find current block at: https://api.explorer.provable.com/v1/testnet/block/height/latest
SCANNER_START_BLOCK=0

# ── Program ──
PROGRAM_ID=automation_scheduled_transfer.aleo
NETWORK=testnet
NETWORK_ID=1

# ── Endpoints (defaults are Provable testnet) ──
API_ENDPOINT=https://api.explorer.provable.com/v1/testnet
QUERY_ENDPOINT=https://api.explorer.provable.com/v1
BROADCAST_ENDPOINT=https://api.explorer.provable.com/v1/testnet/transaction/broadcast

# ── Intervals ──
BLOCK_INTERVAL=15000   # ms between block height checks (default: 15s)
SCAN_INTERVAL=60000    # ms between record scans (default: 60s)

# ── HTTP server ports ──
API_PORT=3001          # keeper-bot API
MANAGER_PORT=3000      # keeper-manager API

# ── CORS (if using a frontend) ──
FRONTEND_ORIGIN=http://localhost:5173

# ── Optional: path to snarkos binary if not in PATH ──
# SNARKOS_PATH=/usr/local/bin/snarkos
